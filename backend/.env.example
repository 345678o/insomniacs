# Valkey / Redis connection
VALKEY_URL=redis://localhost:6379

# Server
PORT=4000

# Conversation TTL (seconds)
CONVERSATION_TTL=1800

# Cache TTL (seconds)
AGENT_CACHE_TTL=300

# Optional: enable real LLM via Google Gemini (leave blank for offline rule-based agent)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
